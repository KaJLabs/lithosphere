# ============================================================================
# Lithosphere Staging Environment Configuration
# ============================================================================
# Staging mirrors production (mainnet) settings with separate credentials.
# Used for pre-mainnet validation via promote.yaml workflow.
# ============================================================================

# ---- General ----
NODE_ENV=production
ENVIRONMENT=staging
LOG_LEVEL=info

# ---- API ----
API_PORT=4000
API_HOST=0.0.0.0
GRAPHQL_PLAYGROUND=true
CORS_ORIGIN=*

# ---- Database (staging-specific) ----
DATABASE_URL=postgresql://lithosphere:lithosphere_staging@postgres:5432/lithosphere
POSTGRES_USER=lithosphere
POSTGRES_PASSWORD=lithosphere_staging
POSTGRES_DB=lithosphere
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# ---- Blockchain RPC (Makalu testnet for staging) ----
LITHO_RPC_URL=https://rpc.litho.ai
LITHO_WS_URL=wss://rpc.litho.ai/ws
LITHO_CHAIN_ID=777777

# ---- Indexer ----
INDEXER_START_BLOCK=0
INDEXER_BATCH_SIZE=100
INDEXER_CONFIRMATIONS=6
INDEXER_POLL_INTERVAL=3000

# ---- Explorer ----
EXPLORER_PORT=3100
CHAIN_NAME=Lithosphere Staging
NEXT_PUBLIC_RPC_URL=https://rpc.litho.ai
NEXT_PUBLIC_CHAIN_ID=lithosphere_777777-1
NEXT_PUBLIC_CHAIN_NAME=Lithosphere Staging

# ---- Faucet ----
FAUCET_PORT=8081
FAUCET_RPC_URL=https://rpc.litho.ai
FAUCET_CHAIN_ID=777777
FAUCET_DRIP_AMOUNT=1
FAUCET_COOLDOWN_HOURS=24
# FAUCET_PRIVATE_KEY= # Set via secrets manager

# ---- Monitoring ----
PROMETHEUS_ENABLED=true
METRICS_PORT=9090
PROMETHEUS_PORT=9091
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=lithosphere-staging

# ---- Container Registry ----
REGISTRY=ghcr.io
IMAGE_TAG=staging

# ---- Feature Flags ----
CONTRACTS_ENABLED=false
MONITORING_ENABLED=true
PROXY_ENABLED=false
